<%= form_with url: me_settings_path, method: :patch, data: { controller: "emoji-picker" } do |form| %>
  <div class="id-form">
    <div class="preview">
      <span class="em" data-emoji-picker-target="preview"><%= user.emoji || "👤" %></span>
      <span>
        <div class="nm" data-emoji-picker-target="namePreview"><%= user.nickname.presence || "你" %></div>
        <div class="label">头像预览</div>
      </span>
    </div>

    <label class="row" for="profile_nickname">昵称</label>
    <%= form.text_field :nickname, id: "profile_nickname", value: user.nickname, maxlength: 16,
          placeholder: "给自己起个名字",
          data: { emoji_picker_target: "nickname", action: "input->emoji-picker#refresh" } %>

    <label class="row" style="margin-top: 24px">选个头像 emoji</label>
    <div class="emoji-grid">
      <% emoji_choices.each do |choice| %>
        <button type="button" class="<%= "sel" if user.emoji == choice %>"
                data-emoji="<%= choice %>" data-action="emoji-picker#pick"><%= choice %></button>
      <% end %>
    </div>

    <% if user.errors[:nickname].any? %>
      <p class="formmsg formerror"><%= user.errors[:nickname].first %></p>
    <% end %>

    <%= form.hidden_field :emoji, value: user.emoji, data: { emoji_picker_target: "emojiInput" } %>
    <button type="submit" class="cta" data-emoji-picker-target="submit" disabled style="margin-top: 24px">🥤 保存</button>
  </div>
<% end %>
