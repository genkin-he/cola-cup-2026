<%= turbo_stream.replace "vote_panel_#{@match.id}" do %>
  <%= render "matches/vote_panel",
        match: @match, status: @status, user_vote: @user_vote,
        next_match_id: @next_match_id, tally: @tally, error: @error %>
<% end %>
<%= turbo_stream.replace "odds_compare_#{@match.id}" do %>
  <%= render "matches/odds_compare",
        match: @match, outcomes: @outcomes, crowd_total: @tally.voters,
        low_sample: @vote_odds&.low_sample?, polymarket_url: @polymarket_url %>
<% end %>
<%= turbo_stream.replace "votes_list_#{@match.id}" do %>
  <%= render "matches/votes_list", match: @match, votes: @votes %>
<% end %>
