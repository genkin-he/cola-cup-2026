<% featured_index = odds_featured_index(outcomes) %>
<% lead_index = odds_lead_index(outcomes) %>
<div class="oc" id="odds_compare_<%= match.id %>">
  <h2 class="disp">赔率对比</h2>

  <% outcomes.each_with_index do |o, i| %>
    <% featured = (i == featured_index) %>
    <div class="<%= featured ? "odds-out featured" : "odds-out" %>">
      <div class="odds-head">
        <span class="o-nm"><%= o[:team_label] %><% if o[:key] != "draw" %><small><%= Match.pick_label(o[:key]) %></small><% end %></span>
        <% if i == lead_index %><%= odds_lead_label(o[:crowd_p], o[:market_p], featured) %><% end %>
      </div>
      <div class="odds-bars">
        <div class="ob">
          <span class="ob-lbl mk">⚽ 市场</span>
          <span class="ob-track"><i class="mk" style="width: <%= odds_clamp_width(o[:market_p]) %>%"></i></span>
          <span class="ob-pct mk"><%= odds_pct_text(o[:market_p]) %></span>
        </div>
        <div class="ob">
          <span class="ob-lbl cr">🥤 同事</span>
          <span class="ob-track"><i class="cr" style="width: <%= odds_clamp_width(o[:crowd_p]) %>%"></i></span>
          <span class="ob-pct cr"><%= odds_pct_text(o[:crowd_p]) %></span>
        </div>
      </div>
    </div>
  <% end %>

  <%# Polymarket keeps moving after we freeze the line — always say which moment
      this market line belongs to. %>
  <p class="oc-foot">
    结算只看同事预测
    <% if low_sample %>· 同事样本少，赔率仅供参考 <% end %>·
    <% if polymarket_url %>
      <a class="market-link" href="<%= polymarket_url %>" target="_blank" rel="noopener noreferrer">市场数据 <span class="arrow">↗</span></a> 仅作参考
    <% else %>
      市场仅作参考
    <% end %>
    <% if market_snapshot %>
      · <%= market_snapshot.locked? ? "锁定于 #{format_snapshot_time(market_snapshot.taken_at)}" : "更新于 #{format_snapshot_time(market_snapshot.taken_at)}" %>
    <% else %>
      · 未开盘
    <% end %>
  </p>
</div>
