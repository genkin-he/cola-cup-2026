<% status = @match.status %>
<section>
  <%= turbo_stream_from "match", @match %>
  <div class="detail-head">
    <%= link_to root_path(anchor: "match_card_#{@match.id}"), class: "back-btn" do %>
      <span class="bk-arrow">←</span> 返回赛程
    <% end %>
    <span class="detail-stage"><%= Match.stage_label(@match.stage) %><% if @match.group_name.present? %> · <%= @match.group_name %><% end %></span>
    <%= status_badge(status) %>
  </div>
  <hr class="rule">

  <div class="detail-vs">
    <span class="team">
      <span class="flag"><%= team_flag(@match.home_team) %></span>
      <span class="nm"><%= team_display_name(@match.home_team, @match.home_label) %></span>
    </span>
    <span class="x"><%= detail_score_token(@match) %></span>
    <span class="team">
      <span class="flag"><%= team_flag(@match.away_team) %></span>
      <span class="nm"><%= team_display_name(@match.away_team, @match.away_label) %></span>
    </span>
  </div>

  <div class="detail-when">
    <%= format_kickoff(@match.kickoff_at) %><% if @match.venue.present? %><span class="venue"> · <%= @match.venue %></span><% end %>
  </div>

  <%# Source order doubles as the mobile stacking order: vote -> odds -> roster
      (the vote panel is the page's primary action, so it gets the first screen).
      Desktop grid-areas put the sticky vote panel in the right rail and let the
      roster spread under the odds (see .detail-cols). %>
  <div class="detail-cols">
    <div class="dc-vote">
      <%= render "matches/vote_panel",
            match: @match, status: status, user_vote: @user_vote,
            next_match_id: @next_match_id, tally: @tally %>
    </div>
    <div class="dc-odds">
      <%= render "matches/odds_compare",
            match: @match, outcomes: @outcomes,
            low_sample: @vote_odds&.low_sample?, polymarket_url: @polymarket_url,
            market_snapshot: @market_odds %>
    </div>
    <div class="dc-roster">
      <%= render "matches/votes_list", match: @match, votes: @votes %>
    </div>
  </div>
</section>
