<div class="teams" id="match_card_teams_<%= match.id %>">
  <span class="t<%= " predicted" unless match.home_team %>"><%= card_team_html(match.home_team, match.home_label) %></span>
  <span class="x"><%= match_score_token(match) %></span>
  <span class="t<%= " predicted" unless match.away_team %>"><%= card_team_html(match.away_team, match.away_label) %></span>
  <% if focus_match?(match) %>
    <span class="focus-mark" data-tip="焦点大战"
          tabindex="0" role="img" aria-label="焦点大战">🔥</span>
  <% end %>
</div>
