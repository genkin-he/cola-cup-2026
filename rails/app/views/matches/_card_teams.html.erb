<div class="teams" id="match_card_teams_<%= match.id %>">
  <span class="t">
    <span class="flag"><%= team_flag(match.home_team) %></span>
    <span class="nm"><%= team_display_name(match.home_team, match.home_label) %></span>
  </span>
  <span class="x"><%= match_score_token(match) %></span>
  <span class="t">
    <span class="flag"><%= team_flag(match.away_team) %></span>
    <span class="nm"><%= team_display_name(match.away_team, match.away_label) %></span>
  </span>
  <% if focus_match?(match) %>
    <span class="focus-mark" data-tip="焦点大战"
          tabindex="0" role="img" aria-label="焦点大战">🔥</span>
  <% end %>
</div>
