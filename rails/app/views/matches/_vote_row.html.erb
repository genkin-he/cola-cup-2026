<% tag_class = { "home" => "tag h", "draw" => "tag d", "away" => "tag a" } %>
<% entry = ledger_by_user[vote.user_id] %>
<div class="vrow" id="vote_<%= vote.id %>">
  <span class="em"><%= vote.user.emoji || "👤" %></span>
  <span class="nm"><%= vote.user.nickname %></span>
  <span class="<%= tag_class[vote.pick] %>"><%= pick_team_label(match, vote.pick) %></span>
  <% if show_result %>
    <% if entry %>
      <span class="res <%= entry.delta >= 0 ? "w" : "l" %>"><%= format_bottles(entry.delta) %> 🥤</span>
    <% end %>
  <% else %>
    <span class="pk">🥤 <b><%= bottles_count(vote.stake) %></b> 瓶</span>
  <% end %>
</div>
